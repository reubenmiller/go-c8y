[
    {
      "name": "getAlarmCollection",
      "method": "GET",
      "description": "Get a collection of alarms based on filter parameters",
      "descriptionLong": "Get a collection of alarms based on filter parameters",
      "examples": {
        "powershell": [
          "Get-AlarmCollection"
        ],
        "go": [
          "c8y alarms get --type value"
        ]
      },
      "path": "alarm/alarms",
      "accept": "application/json",
      "alias": {
        "go": "get",
        "powershell": "Get-AlarmCollection"
      },
      "queryParameters": [
        {
          "name": "source",
          "type": "string",
          "description": "Source device id."
        },
        {
          "name": "dateFrom",
          "type": "datetime",
          "description": "Start date or date and time of alarm occurrence."
        },
        {
          "name": "dateTo",
          "type": "datetime",
          "description": "End date or date and time of alarm occurrence."
        },
        {
          "name": "type",
          "type": "string",
          "description": "Alarm type."
        },
        {
          "name": "fragmentType",
          "type": "string",
          "description": ""
        },
        {
          "name": "status",
          "type": "string",
          "description": "Comma separated alarm statuses, for example ACTIVE,CLEARED.",
          "validationSet": [
            "ACTIVE",
            "ACKNOWLEDGED",
            "CLEARED"
          ]
        },
        {
          "name": "severity",
          "type": "string",
          "description": "Alarm severity, for example MINOR.",
          "validationSet": [
            "CRITICAL",
            "MAJOR",
            "MINOR",
            "WARNING"
          ]
        },
        {
          "name": "resolved",
          "type": "boolean",
          "description": "When set to true only resolved alarms will be removed (the one with status CLEARED), false means alarms with status ACTIVE or ACKNOWLEDGED."
        },
        {
          "name": "withAssets",
          "type": "boolean",
          "description": "Include assets"
        },
        {
          "name": "withDevices",
          "type": "boolean",
          "description": "Include devices"
        }
      ]
    },
    {
      "name": "newAlarm",
      "method": "POST",
      "path": "alarm/alarms",
      "accept": "application/json",
      "description": "Create a new alarm",
      "descriptionLong": "Create a new alarm",
      "alias": {
        "go": "new",
        "powershell": "New-Alarm"
      },
      "body": [
        {
          "name": "source",
          "type": "string",
