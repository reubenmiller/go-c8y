{
  "information": {
    "name": "users",
    "description": "Cumulocity users",
    "descriptionLong": "REST endpoint to interact with Cumulocity users",
    "link": "https://cumulocity.com/guides/reference/users/#user"
  },
  "endpoints": [
    {
      "name": "getUserCurrent",
      "description": "Get user",
      "method": "GET",
      "path": "/user/currentUser",
      "accept": "application/vnd.com.nsn.cumulocity.currentUser+json",
      "alias": {
        "go": "getCurrentUser",
        "powershell": "Get-CurrentUser"
      }
    },
    {
      "name": "updateUserCurrent",
      "description": "Update the current user",
      "method": "PUT",
      "path": "/user/currentUser",
      "accept": "application/vnd.com.nsn.cumulocity.currentUser+json",
      "alias": {
        "go": "getCurrentUser",
        "powershell": "Get-CurrentUser"
      },
      "body": [
        {
          "name": "firstName",
          "type": "string",
          "required": false,
          "description": "User first name"
        },
        {
          "name": "lastName",
          "type": "string",
          "required": false,
          "description": "User last name"
        },
        {
          "name": "phone",
          "type": "string",
          "required": false,
          "description": "User phone number. Format: '+[country code][number]', has to be a valid MSISDN"
        },
        {
          "name": "email",
          "type": "string",
          "required": false,
          "description": "User email address"
        },
        {
          "name": "enabled",
          "type": "string",
          "required": false,
          "validateSet": [
            "true",
            "false"
          ],
          "description": "User activation status (true/false)"
        },
        {
          "name": "password",
          "type": "string",
          "required": false,
          "description": "User password. Min: 6, max: 32 characters. Only Latin1 chars allowed"
        }
      ]
    },
    {
      "name": "getUserCollection",
      "method": "GET",
      "description": "Get a collection of users based on filter parameters",
      "descriptionLong": "Get a collection of users based on filter parameters",
      "examples": {
        "powershell": [
          "Get a list of users\nGet-UserCollection"
        ],
        "go": [
          "retrieve users, where username starts with 'js', and every user belongs to one of the groups 2, 3 or 4, and the owner is 'admin', and is not a device user.\nc8y user getCollection --username js --groups 2,3,4 --owner admin"
        ]
      },
      "path": "/user/{tenant}/users",
      "accept": "application/vnd.com.nsn.cumulocity.userCollection+json",
      "alias": {
        "go": "getCollection",
        "powershell": "Get-UserCollection"
      },
      "pathParameters": [
        {
          "name": "tenant",
          "type": "tenant",
          "description": "Tenant"
        }
      ],
      "queryParameters": [
        {
          "name": "username",
          "type": "string",
          "description": "prefix or full username"
        },
        {
          "name": "groups",
          "type": "string",
          "description": "numeric group identifiers separated by commas; result will contain only users which belong to at least one of specified groups"
        },
        {
          "name": "owner",
          "type": "string",
          "description": "exact username"
        },
        {
          "name": "onlyDevices",
          "type": "boolean",
          "description": "If set to 'true', result will contain only users created during bootstrap process (starting with 'device_'). If flag is absent (or false) the result will not contain 'device_' users."
        },
        {
          "name": "withSubusersCount",
          "type": "boolean",
          "description": "if set to 'true', then each of returned users will contain additional field 'subusersCount' - number of direct subusers (users with corresponding 'owner')."
        }
      ]
    },
    {
      "name": "newUser",
      "description": "Create a new user within the collection",
      "method": "POST",
      "path": "user/{tenant}/users",
      "accept": "application/vnd.com.nsn.cumulocity.user+json",
      "alias": {
        "go": "create",
        "powershell": "New-User"
      },
      "body": [
        {
          "name": "userName",
          "type": "string",
          "required": true,
          "description": "User name, unique for a given domain. Max: 1000 characters"
        },
        {
          "name": "firstName",
          "type": "string",
          "required": false,
          "description": "User first name"
        },
        {
          "name": "lastName",
          "type": "string",
          "required": false,
          "description": "User last name"
        },
        {
          "name": "phone",
          "type": "string",
          "required": false,
          "description": "User phone number. Format: '+[country code][number]', has to be a valid MSISDN"
        },
        {
          "name": "email",
          "type": "string",
          "required": false,
          "description": "User email address"
        },
        {
          "name": "enabled",
          "type": "boolean",
          "required": false,
          "description": "User activation status (true/false)"
        },
        {
          "name": "password",
          "type": "string",
          "required": true,
          "description": "User password. Min: 6, max: 32 characters. Only Latin1 chars allowed"
        },
        {
          "name": "sendPasswordResetEmail",
          "type": "boolean",
          "required": false,
          "validateSet": [
            "true",
            "false"
          ],
          "description": "User activation status (true/false)"
        },
        {
          "name": "customProperties",
          "type": "json",
          "required": false,
          "description": "User password. Min: 6, max: 32 characters. Only Latin1 chars allowed"
        }
      ]
    },
    {
      "name": "getUser",
      "description": "Get user",
      "method": "GET",
      "path": "user/{tenant}/users/{id}",
      "accept": "application/vnd.com.nsn.cumulocity.user+json",
      "alias": {
        "go": "get",
        "powershell": "Get-User"
      },
      "pathParameters": [
        {
          "name": "tenant",
          "type": "string",
          "required": false,
          "description": "Tenant"
        },
        {
          "name": "id",
          "type": "string",
          "required": true,
          "description": "User id"
        }
      ]
    },
    {
      "name": "getUserByName",
      "description": "Get user by username",
      "method": "GET",
      "path": "user/{tenant}/userByName/{name}",
      "accept": "application/vnd.com.nsn.cumulocity.user+json",
      "alias": {
        "go": "get",
        "powershell": "Get-UserByName"
      },
      "pathParameters": [
        {
          "name": "tenant",
          "type": "string",
          "required": false,
          "description": "Tenant"
        },
        {
          "name": "name",
          "type": "string",
          "required": true,
          "description": "Username"
        }
      ]
    },
    {
      "name": "deleteUser",
      "description": "Delete user",
      "method": "DELETE",
      "path": "user/{tenant}/users/{id}}",
      "accept": "application/json",
      "alias": {
        "go": "delete",
        "powershell": "Remove-User"
      },
      "pathParameters": [
        {
          "name": "tenant",
          "type": "string",
          "required": false,
          "description": "Tenant"
        },
        {
          "name": "id",
          "type": "string",
          "required": true,
          "description": "User id"
        }
      ]
    },
    {
      "name": "updateUser",
      "description": "Update user",
      "method": "POST",
      "path": "user/{tenant}/users/{id}",
      "accept": "application/vnd.com.nsn.cumulocity.user+json",
      "alias": {
        "go": "update",
        "powershell": "Update-User"
      },
      "body": [
        {
          "name": "firstName",
          "type": "string",
          "required": false,
          "description": "User first name"
        },
        {
          "name": "lastName",
          "type": "string",
          "required": false,
          "description": "User last name"
        },
        {
          "name": "phone",
          "type": "string",
          "required": false,
          "description": "User phone number. Format: '+[country code][number]', has to be a valid MSISDN"
        },
        {
          "name": "email",
          "type": "string",
          "required": false,
          "description": "User email address"
        },
        {
          "name": "enabled",
          "type": "boolean",
          "required": false,
          "description": "User activation status (true/false)"
        },
        {
          "name": "password",
          "type": "string",
          "required": false,
          "description": "User password. Min: 6, max: 32 characters. Only Latin1 chars allowed"
        },
        {
          "name": "sendPasswordResetEmail",
          "type": "boolean",
          "required": false,
          "validateSet": [
            "true",
            "false"
          ],
          "description": "User activation status (true/false)"
        },
        {
          "name": "customProperties",
          "type": "json",
          "required": false,
          "description": "User password. Min: 6, max: 32 characters. Only Latin1 chars allowed"
        }
      ]
    }
  ]
}